    "def applay_controlled_U(qc, n, angle):\n",
    "    repetitions = 1\n",
    "    for qubit in range(n):\n",
    "        for repetition in range(repetitions):\n",
    "            qc.cp(angle, qubit, n)\n",
    "        repetitions *= 2"
   ]
