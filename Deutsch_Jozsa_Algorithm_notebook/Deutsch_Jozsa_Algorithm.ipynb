   "source": [
    "from qiskit import QuantumCircuit\n",
    "\n",
    "def oracle(case, n):\n",
    "    qc =QuantumCircuit(n+1)\n",
    "\n",
    "    if case = \"balanced\":\n",
    "        for qubit in range(n):\n",
    "            qc.cx(qubit, n)\n",
    "\n",
    "    return oracle"
   ]
  }
